      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="ZSOAP Setup" enabled="true">
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="script">import com.zimbra.jmeter.Zimbra;

Zimbra soap = new Zimbra(props, &quot;ZSOAP&quot;);
vars.putObject(&quot;ZSOAP&quot;, soap);

String url = &quot;https://&quot; + props.get(&quot;HTTP.server&quot;);
String admin = url + &quot;:&quot; + props.get(&quot;HTTP.admin.port&quot;) + &quot;/service/admin/soap&quot;;
vars.put(&quot;ADMIN&quot;, admin);

if (!props.get(&quot;HTTP.port&quot;).equals(&quot;&quot;)) {
    url = url + &quot;:&quot; + props.get(&quot;HTTP.port&quot;);
}
url = url + &quot;/service/soap&quot;;
vars.put(&quot;URL&quot;, url);

long startEpoch = ${__timeShift(,,-P5D,,)}L;
long endEpoch = ${__timeShift(,,P14D,,)}L;

vars.put(&quot;searchStartEpochTime&quot;, String.valueOf(startEpoch));
vars.put(&quot;searchEndEpochTime&quot;, String.valueOf(endEpoch));</stringProp>
        <stringProp name="scriptLanguage">groovy</stringProp>
      </JSR223PreProcessor>
